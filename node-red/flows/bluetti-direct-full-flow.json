    "repeat": "",
    "crontab": "",
    "once": false,
    "onceDelay": 0.1,
    "topic": "",
    "payload": "{\"command\":\"ac_on\"}",
    "payloadType": "json",
    "x": 140,
    "y": 190,
    "wires": [["bluetti-direct-001"]]
  },
  {
    "id": "inject-ac-off-001",
    "type": "inject",
    "z": "bluetti-tab-001",
    "name": "AC Desligar",
    "props": [{"p": "payload"}],
    "repeat": "",
    "crontab": "",
    "once": false,
    "onceDelay": 0.1,
    "topic": "",
    "payload": "{\"command\":\"ac_off\"}",
    "payloadType": "json",
    "x": 150,
    "y": 240,
    "wires": [["bluetti-direct-001"]]
  },
  {
    "id": "inject-dc-on-001",
    "type": "inject",
    "z": "bluetti-tab-001",
    "name": "DC Ligar",
    "props": [{"p": "payload"}],
    "repeat": "",
    "crontab": "",
    "once": false,
