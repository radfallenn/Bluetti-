    "crontab": "",
    "once": true,
    "onceDelay": "2",
    "topic": "",
    "payload": "{\"command\":\"connect\"}",
    "payloadType": "json",
    "x": 150,
    "y": 80,
    "wires": [["bluetti-direct-001"]]
  },
  {
